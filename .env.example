# Runtime
PIE_APP_NAME=Property Intelligence Engine
PIE_APP_VERSION=0.1.0
PIE_ENVIRONMENT=local
PIE_API_PREFIX=/api/v1
PIE_DOCS_ENABLED=true
PIE_AUTH_ENABLED=false
# PIE_API_KEY=replace-with-a-long-random-value
PIE_ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
PIE_CORS_ORIGINS=[]
PIE_MAX_REQUEST_BYTES=65536
PIE_LOG_LEVEL=INFO
PIE_LOG_JSON=true

# Compose-only host binding (set 0.0.0.0 only behind an intended network boundary)
PIE_BIND_HOST=127.0.0.1
PIE_API_PORT=8000

# OpenAI (leave blank to use deterministic copy generation)
PIE_LLM_ENABLED=true
PIE_LLM_REQUIRED=false
# PIE_OPENAI_API_KEY=
PIE_OPENAI_MODEL=gpt-5.6-sol
PIE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PIE_EMBEDDING_DIMENSIONS=1536
PIE_LLM_TIMEOUT_SECONDS=45
PIE_LLM_MAX_RETRIES=2

# Retrieval
PIE_VECTOR_STORE_ENABLED=true
PIE_VECTOR_STORE_REQUIRED=false
PIE_QDRANT_URL=http://localhost:6333
# Compose uses its internal service by default; override only for an external Qdrant.
# PIE_COMPOSE_QDRANT_URL=https://qdrant.example.com:6333
PIE_QDRANT_COLLECTION=listing_guidance_v1
PIE_QDRANT_TIMEOUT_SECONDS=10
PIE_RETRIEVAL_LIMIT=5
# PIE_QDRANT_API_KEY=replace-with-a-long-random-value
QDRANT_HTTP_PORT=6333

# Optional observability
# PIE_SENTRY_DSN=
PIE_SENTRY_TRACES_SAMPLE_RATE=0.0
